---
export const prerender = true;
import { getCollection } from "astro:content";
import General from "../../layouts/General.astro";
import PostCard from "@components/utilities/PostCard.astro";
export async function getStaticPaths() {
  // ⚡ Bolt Optimization: Move collection fetching and filtering into getStaticPaths.
  // This changes build complexity from O(N^2) to O(N) by fetching the entire collection
  // only once per build rather than once per generated page.
  const [tags, allPosts] = await Promise.all([
    getCollection("tags"),
    getCollection("blog"),
  ]);

  // ⚡ Bolt Optimization: Replace O(N^2) nested loop with O(N) hash map lookup
  const postsByTag = new Map();
  for (const post of allPosts) {
    for (const t of post.data.tags) {
      if (!postsByTag.has(t.id)) postsByTag.set(t.id, []);
      postsByTag.get(t.id).push(post);
    }
  }

  return tags.map((tag) => {
    const posts = postsByTag.get(tag.id) || [];

    return {
      params: { id: tag.id },
      props: { tag, posts },
    };
  });
}

const { tag, posts } = Astro.props;
---

<General
  title={"Tag | " + tag}
  description={"List of blog posts with the tag " + tag}
>
  <section>
    <h1>{tag.data.name}</h1>
    <p>{tag.data.description}</p>
    {
      posts.length > 0 && (
        <section>
          <h2>Posts in this section</h2>
          <ul class="grid grid-cols-2 gap-2">
            {posts.map((post, index) => (
              <PostCard {...post} class="col-span-1" eager={index < 2} />
            ))}
          </ul>
        </section>
      )
    }
  </section>
</General>
