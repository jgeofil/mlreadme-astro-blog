---
import { type Socials } from '@db/supabase'

interface Props {
	social: Socials
}
const { social } = Astro.props as Props
import Icon from '@components/base/Icon.astro'
---

{
	social.url ? (
		<a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name || 'Visit our social media page'}>
			<Icon name={social.name} href={social.color} />
		</a>
	) : (
		<span aria-label={social.name || 'Visit our social media page'}>
			<Icon name={social.name} href={social.color} />
		</span>
	)
}
