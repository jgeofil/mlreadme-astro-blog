---
import { type Socials } from "@db/supabase";

interface Props {
  social: Socials;
}
const { social } = Astro.props as Props;
import Icon from "@components/base/Icon.astro";

const safeUrl = social.url && (social.url.startsWith('http://') || social.url.startsWith('https://') || social.url.startsWith('/'))
  ? social.url
  : '#';
---

<a href={safeUrl} target="_blank" rel="noopener noreferrer">
  <Icon name={social.name} href={social.color} />
</a>
